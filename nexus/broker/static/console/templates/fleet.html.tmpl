{{/* Fleet + graph status pane. All fields auto-escaped by html/template. */}}
<h2>Fleet status</h2>
{{if not .WorkersConfigured}}
  <p class="empty">Worker status store not configured on this broker.</p>
{{else if not .Workers}}
  <p class="empty">No workers have reported in.</p>
{{else}}
<table class="fleet-table">
  <thead>
    <tr>
      <th>Agent</th><th>Role</th><th>Personality</th><th>State</th><th>Work item</th>
      <th>Turns</th><th>Tokens</th>
      <th>Last heartbeat</th><th>Auth</th><th>CLI</th>
    </tr>
  </thead>
  <tbody>
  {{range .Workers}}
    <tr class="fleet-row-{{.StatusClass}}">
      <td>{{.Agent}}</td>
      <td>{{.Role}}</td>
      <td>{{.Personality}}</td>
      <td><span class="state-badge state-{{.StatusClass}}">{{.State}}</span></td>
      <td>{{.WorkItemID}}</td>
      <td>{{.Turns}}</td>
      <td>{{.TokensUsed}}</td>
      <td>{{.LastHeartbeatDisplay}}</td>
      <td>{{if .AuthOk}}ok{{else}}<span class="auth-bad">FAIL</span>{{end}}</td>
      <td>{{.CLIVersion}}</td>
    </tr>
  {{end}}
  </tbody>
</table>
{{end}}

<h2>Recently completed</h2>
{{if not .RunsConfigured}}
  <p class="empty">Runs store not configured on this broker.</p>
{{else if not .CompletedRuns}}
  <p class="empty">No completed runs yet.</p>
{{else}}
<table class="fleet-table">
  <thead>
    <tr>
      <th>Agent</th><th>Role</th><th>Ticket</th><th>Outcome</th>
      <th>Duration</th><th>Completed</th>
    </tr>
  </thead>
  <tbody>
  {{range .CompletedRuns}}
    <tr>
      <td>{{.Agent}}</td>
      <td>{{.Role}}</td>
      <td>{{.Ticket}}</td>
      <td><span class="state-badge state-{{.OutcomeClass}}">{{.Outcome}}</span></td>
      <td>{{.DurationDisplay}}</td>
      <td>{{.CompletedDisplay}}</td>
    </tr>
  {{end}}
  </tbody>
</table>
{{end}}

<h2>Work graph</h2>
<p class="graph-status-todo">
  {{.GraphStatusNote}}
</p>
