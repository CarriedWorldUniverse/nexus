# Go build artifacts
bin/
*.exe
*.test

# IDE / OS
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# Credentials — never commit
.credentials/
**/.credentials/
*.pem
*.key
*.env
.env.*
credentials.json
*-credentials.json

# Runtime / operational data — never commit
# (note: `runtime/` the directory IS source code; we're excluding runtime *artifacts*)
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3
logs/
**/logs/
**/session/
agents/*/session/
agents/*/logs/
agents/*/tmp/
agents/*/.credentials/
tmp/

# Vector index files (if ever dumped separately)
*.vec
*.index

agents/*/cursor
*.exe~


nexus-imap-mcp
nexus-jira-mcp
.worktree/
/site/

# Binaries build to bin/ (Makefile: go build -o bin/$@), which is ignored
# above. Do NOT add bare-named root ignores per binary — they shadow
# same-named source dirs (e.g. /nexus vs the nexus/ package tree). Build
# with `make` or `-o bin/`, not a bare `go build ./cmd/x` from the root.
# Exception: agentfunnel is a builder-produced binary that builders have committed by accident; ignore to prevent repeat.
agentfunnel


# Skill artifacts (writing-plans, brainstorming, etc.) live in shadow's
# working tree, not in this repo. Defensive ignore in case they leak.
docs/superpowers/
.worktrees/
