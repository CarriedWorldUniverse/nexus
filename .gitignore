# Go build artifacts
bin/
*.exe
*.test

# IDE / OS
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# Credentials — never commit
.credentials/
**/.credentials/
*.pem
*.key
*.env
.env.*
credentials.json
*-credentials.json

# Runtime / operational data — never commit
# (note: `runtime/` the directory IS source code; we're excluding runtime *artifacts*)
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3
logs/
**/logs/
**/session/
agents/*/session/
agents/*/logs/
agents/*/tmp/
agents/*/.credentials/
tmp/

# Vector index files (if ever dumped separately)
*.vec
*.index

agents/*/cursor
*.exe~


nexus-imap-mcp
nexus-jira-mcp
.worktree/
/site/

# Bare-named Go build outputs at repo root (no .exe extension on Unix)
/agentfunnel
/aspect
# A bare-named `nexus` binary collides with the nexus/ source directory.
# Ignore a root *file* named nexus, but re-include the directory: the
# trailing-slash negation matches directories only, so source under nexus/
# is never shadowed.
/nexus
!/nexus/

# Skill artifacts (writing-plans, brainstorming, etc.) live in shadow's
# working tree, not in this repo. Defensive ignore in case they leak.
docs/superpowers/
.worktrees/
